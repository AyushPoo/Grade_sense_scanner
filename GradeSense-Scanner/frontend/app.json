{
  "expo": {
    "name": "GradeSense",
    "slug": "gradesense-scanner",
    "version": "1.0.26",
    "orientation": "default",
    "icon": "./assets/images/icon.png",
    "scheme": [
      "gradesense",
      "com.ayushp123.gradesensescanner"
    ],
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Scan student answer papers with camera",
        "NSMicrophoneUsageDescription": "Record audio feedback for scans",
        "NSPhotoLibraryUsageDescription": "Save scanned documents to gallery",
        "NSMotionUsageDescription": "Detect stability for auto-capture",
        "UISupportedInterfaceOrientations": [
          "UIInterfaceOrientationPortrait",
          "UIInterfaceOrientationLandscapeLeft",
          "UIInterfaceOrientationLandscapeRight"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "edgeToEdgeEnabled": true,
      "softwareKeyboardLayoutMode": "resize",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.VIBRATE",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.WAKE_LOCK"
      ],
      "package": "com.ayushp123.gradesensescanner"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-screen-orientation",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 320,
          "resizeMode": "contain",
          "backgroundColor": "#FFFFFF"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-icon.png",
          "color": "#FF6B35",
          "defaultChannel": "grading-complete"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow GradeSense to access your camera for scanning documents"
        }
      ],
      [
        "react-native-document-scanner-plugin",
        {
          "cameraPermission": "Allow GradeSense to access your camera for scanning documents"
        }
      ],
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Allow GradeSense to use your microphone for voice comments",
          "speechRecognitionPermission": "Allow GradeSense to transcribe teacher voice comments",
          "androidSpeechServicePackages": [
            "com.google.android.googlequicksearchbox"
          ]
        }
      ],
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "359d678e-04cf-4780-82cf-f9392c2a3d45"
      }
    }
  }
}
